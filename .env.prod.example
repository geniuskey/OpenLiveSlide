# Copy to .env.prod and edit, then:
#   docker compose -f docker/docker-compose.prod.yml --env-file .env.prod up --build -d

POSTGRES_USER=openliveslide
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=openliveslide

# Random 32+ char strings (e.g. `openssl rand -hex 32`).
AUTH_SECRET=replace-with-32-byte-random-hex
PRESENTER_TOKEN_SECRET=replace-with-32-byte-random-hex

# How clients reach the realtime server. Use the public hostname they will
# WebSocket against — usually the same domain as the web app on its own port
# or behind a reverse proxy.
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Public URL of the web app (used for NextAuth callback and CORS).
NEXTAUTH_URL=http://localhost:3000

WEB_PORT=3000
REALTIME_PORT=4000
